# Local default
WHISPER_MODEL=small
DEVICE=cpu
COMPUTE_TYPE=int8

# Modal deployment example
# WHISPER_MODEL=large-v3-turbo
# DEVICE=cuda
# COMPUTE_TYPE=float16

SAMPLE_RATE=16000
LANGUAGE=ko

VOICE_RMS_THRESHOLD=0.0015
MIN_AUDIO_MS=500
FINAL_SILENCE_MS=1200
PREROLL_MS=300

PARTIAL_ENABLED=true
PARTIAL_INTERVAL_MS=900
PARTIAL_MIN_AUDIO_MS=900
PARTIAL_MAX_AUDIO_SEC=14

# Try true only after testing noisy environments.
WHISPER_VAD_FILTER=false

# Off by default because transcripts can contain personal data.
ENABLE_LOGS=false
LOG_DIR=logs